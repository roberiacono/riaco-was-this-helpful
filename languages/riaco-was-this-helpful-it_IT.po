#. Description of the plugin
#: riaco-was-this-helpful.php
msgid "A lightweight plugin that adds a \"Was this helpful?\" thumbs up/down feedback box to your posts and pages — improve content quality through direct user feedback."
msgstr "Un plugin leggero che aggiunge una casella di feedback \"È stato utile?\" con pollice su/giù ai tuoi articoli e pagine — migliora la qualità dei contenuti attraverso il feedback diretto degli utenti."

#. Author of the plugin
#: riaco-was-this-helpful.php
msgid "Roberto Iacono"
msgstr ""

#. Author URI of the plugin
#: riaco-was-this-helpful.php
msgid "https://www.robertoiacono.it/"
